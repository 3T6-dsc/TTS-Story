{
  "daemon": true,
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "run.bat",
        "on": "{{platform === 'win32'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "chmod +x run.sh && ./run.sh",
        "on": "{{platform !== 'win32'}}"
      }
    },
    {
      "method": "local.set",
      "params": {
        "url": "http://localhost:5000"
      }
    }
  ]
}
