{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "git pull"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "setup.bat",
        "on": "{{platform === 'win32'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "chmod +x setup.sh && ./setup.sh",
        "on": "{{platform !== 'win32'}}"
      }
    }
  ]
}
